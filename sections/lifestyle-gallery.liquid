{%- style -%}
  .lifestyle-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .lifestyle-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lifestyle__head {
    text-align: center;
    max-width: 60rem;
    margin: 0 auto 4rem;
  }

  .lifestyle__masonry {
    column-count: 2;
    column-gap: 1.4rem;
  }

  @media screen and (min-width: 750px) {
    .lifestyle__masonry { column-count: 3; column-gap: 1.8rem; }
  }

  @media screen and (min-width: 1200px) {
    .lifestyle__masonry { column-count: {{ section.settings.columns }}; }
  }

  .lifestyle__item {
    break-inside: avoid;
    margin-bottom: 1.4rem;
    display: block;
    overflow: hidden;
    border-radius: var(--gsr-radius, 16px);
    position: relative;
  }

  @media screen and (min-width: 750px) {
    .lifestyle__item { margin-bottom: 1.8rem; }
  }

  .lifestyle__item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 1.1s var(--gsr-ease, ease);
  }

  .lifestyle__item:hover img { transform: scale(1.06); }

  .lifestyle__placeholder {
    background: rgba(var(--color-foreground), 0.06);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
  }
  .lifestyle__placeholder svg { width: 40%; opacity: 0.4; }
{%- endstyle -%}

<div class="lifestyle color-{{ section.settings.color_scheme }} gradient">
  <div class="lifestyle-{{ section.id }} page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="lifestyle__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="gsr-eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="title {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color: var(--gsr-muted); margin-top: 0.8rem;">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lifestyle__masonry">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="lifestyle__item" {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="lifestyle__item" {{ block.shopify_attributes }}>
        {%- endif -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw',
              widths: '200, 400, 600, 800, 1000' }}
          {%- else -%}
            <div class="lifestyle__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div style="text-align:center; margin-top: 3.6rem;">
        <a href="{{ section.settings.button_link | default: '#' }}" class="button button--secondary">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Lifestyle gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "As seen on you" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "@gsrallure" },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h0", "label": "Extra large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Tag us to be featured." },
    {
      "type": "range",
      "id": "columns",
      "min": 3,
      "max": 5,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 4
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Follow along" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 88 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Lifestyle gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
